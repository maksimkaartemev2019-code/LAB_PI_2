<Application x:Class="LAB_PI_2.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#115E59"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="LineBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="SoftBrush" Color="#ECFDF5"/>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Margin" Value="18"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Margin" Value="0,5,12,5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Margin" Value="0,5,12,5"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Margin" Value="0,8,10,0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftBrush}"/>
            <Setter Property="BorderBrush" Value="#99F6E4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,5,12,5"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Application.Resources>
</Application>
