<UserControl x:Class="LAB_PI_2.Views.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <GroupBox Header="Двухсторонняя привязка UI -> UI">
                <StackPanel>
                    <WrapPanel>
                        <TextBox x:Name="MirrorSource" Text="Два элемента связаны напрямую"/>
                        <TextBox Text="{Binding Text, ElementName=MirrorSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,10,0,0" Text="{Binding Text, ElementName=MirrorSource}"/>
                    </WrapPanel>
                    <WrapPanel>
                        <Slider x:Name="TwoWaySlider" Width="260" Minimum="0" Maximum="100" Value="30"/>
                        <TextBox Width="80" Text="{Binding Value, ElementName=TwoWaySlider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Двухсторонняя привязка через ViewModel и UpdateSourceTrigger">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="PropertyChanged обновляет источник при каждом вводе"/>
                    <WrapPanel>
                        <TextBox Text="{Binding LiveText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding LiveText}"/>
                        </Border>
                    </WrapPanel>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="LostFocus обновляет источник после выхода из поля"/>
                    <WrapPanel>
                        <TextBox Text="{Binding LostFocusText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding LostFocusText}"/>
                        </Border>
                    </WrapPanel>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="Explicit обновляет источник только командой"/>
                    <WrapPanel>
                        <TextBox x:Name="ExplicitBox" Text="{Binding ExplicitText, Mode=TwoWay, UpdateSourceTrigger=Explicit}"/>
                        <Button Content="Обновить Explicit" Command="{Binding ApplyExplicitCommand}" CommandParameter="{Binding ElementName=ExplicitBox}"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding ExplicitText}"/>
                        </Border>
                    </WrapPanel>

                    <WrapPanel>
                        <Slider Width="260" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,12,7"/>
                        <TextBox Width="80" Text="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}"/>
                        <Button Content="Описать значения" Command="{Binding DescribeCommand}"/>
                    </WrapPanel>
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="{Binding Summary}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
