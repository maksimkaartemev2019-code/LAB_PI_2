<UserControl x:Class="LAB_PI_2.Views.OneWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <GroupBox Header="Односторонняя привязка UI -> UI">
                <StackPanel>
                    <WrapPanel>
                        <TextBox x:Name="ReadSource" Text="Источник интерфейса"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding Text, ElementName=ReadSource, Mode=OneWay}"/>
                        </Border>
                    </WrapPanel>
                    <WrapPanel>
                        <CheckBox x:Name="AvailabilityCheck" Content="Доступно" IsChecked="True" Margin="0,10,12,5"/>
                        <TextBlock Margin="0,10,0,0" Text="{Binding IsChecked, ElementName=AvailabilityCheck, StringFormat=Состояние: {0}}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Односторонняя привязка ViewModel -> UI">
                <StackPanel>
                    <WrapPanel>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding SourceMessage, Mode=OneWay}"/>
                        </Border>
                        <ProgressBar Width="260" Height="22" Minimum="0" Maximum="40" Value="{Binding Temperature, Mode=OneWay}"/>
                        <TextBlock Margin="12,8,0,0" Text="{Binding Temperature, StringFormat=Температура: {0:0} °C}"/>
                    </WrapPanel>
                    <CheckBox Content="Поле доступно из VM" IsChecked="{Binding IsAvailable, Mode=OneWay}" IsHitTestVisible="False" Margin="0,8,0,0"/>
                    <Button Content="Изменить источник" Command="{Binding ChangeSourceCommand}"/>
                    <TextBlock Margin="0,12,0,0" Text="{Binding ChangesCount, StringFormat=Команда выполнена раз: {0}}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
