<UserControl x:Class="LAB_PI_2.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <GroupBox Header="Прямая привязка к элементам интерфейса">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="TextBox -> TextBlock, Slider -> ProgressBar"/>
                    <WrapPanel>
                        <TextBox x:Name="DirectTextBox" Text="Прямое значение"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding Text, ElementName=DirectTextBox}"/>
                        </Border>
                    </WrapPanel>
                    <WrapPanel>
                        <Slider x:Name="DirectSlider" Width="240" Minimum="0" Maximum="100" Value="55" Margin="0,7,12,7"/>
                        <ProgressBar Width="260" Height="22" Minimum="0" Maximum="100" Value="{Binding Value, ElementName=DirectSlider}"/>
                        <TextBlock Margin="12,8,0,0" Text="{Binding Value, ElementName=DirectSlider, StringFormat={}{0:0}%}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Привязка через визуальную модель">
                <StackPanel>
                    <WrapPanel>
                        <TextBox Text="{Binding UserName}"/>
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"/>
                        <CheckBox Content="Уведомления включены" IsChecked="{Binding NotificationsEnabled}" Margin="0,10,12,5"/>
                    </WrapPanel>
                    <WrapPanel>
                        <Slider Width="260" Minimum="0" Maximum="100" Value="{Binding Progress}" Margin="0,7,12,7"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding Progress, StringFormat=Прогресс: {0:0}%}"/>
                        </Border>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Content="Применить" Command="{Binding ApplyCommand}"/>
                        <Button Content="Сбросить" Command="{Binding ResetCommand}"/>
                    </WrapPanel>
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="{Binding CommandResult}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
